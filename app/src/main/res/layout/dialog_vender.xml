<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Comprador *" android:textSize="12sp" android:textStyle="bold"
        android:textColor="#6B7280" android:layout_marginBottom="4dp" />
    <EditText android:id="@+id/etComprador"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Nombre del comprador"
        android:inputType="textPersonName"
        android:layout_marginBottom="12dp" />

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Teléfono" android:textSize="12sp" android:textStyle="bold"
        android:textColor="#6B7280" android:layout_marginBottom="4dp" />
    <EditText android:id="@+id/etTelefono"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="Número de teléfono"
        android:inputType="phone"
        android:layout_marginBottom="12dp" />

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Precio" android:textSize="12sp" android:textStyle="bold"
        android:textColor="#6B7280" android:layout_marginBottom="4dp" />
    <EditText android:id="@+id/etPrecio"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:hint="0.00"
        android:inputType="numberDecimal"
        android:layout_marginBottom="12dp" />

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Notas" android:textSize="12sp" android:textStyle="bold"
        android:textColor="#6B7280" android:layout_marginBottom="4dp" />
    <EditText android:id="@+id/etNotas"
        android:layout_width="match_parent" android:layout_height="70dp"
        android:hint="Notas opcionales"
        android:inputType="textMultiLine"
        android:gravity="top" />
</LinearLayout>
